# Keycloak Configuration
KEYCLOAK_URL=http://localhost:8081
KEYCLOAK_REALM=idp

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=idp_db
DB_USER=idp_user
DB_PASSWORD=secure_password

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT Secret (for token validation)
JWT_SECRET=your-secret-key-here

# Server
NODE_ENV=development
PORT=3000
